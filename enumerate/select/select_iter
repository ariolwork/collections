package en_select

import "iter"

type selectIter[T, R any] struct {
	currentId int
	subEnum   iter.Seq[T]
	applyFunc func(T) R
}

func (s *selectIter[T, R]) GetLen() int {
	return len(s.subEnum)
}

func (s *selectIter[T, R]) Next() R {
	if s.currentId >= len(s.subEnum) {
		panic("out of range access attempt")
	}

	val := s.subEnum[s.currentId]

	s.currentId += 1

	return s.applyFunc(val)
}

func (s *selectIter[T, R]) HasNext() bool {
	return s.currentId < len(s.subEnum)
}
